# AspireGate marketing site — Sanity blog (public read-only API)
# No secret token is used in the browser; these IDs are public.
#
# Local: copy this file to `.env` and fill in the project id.
# Production: set the same variables in your host’s build environment (Vercel,
# Netlify, Cloudflare Pages, etc.). Vite inlines `VITE_*` at build time.

VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-05-01

# Optional: site origin for canonical URLs & Open Graph (no trailing slash)
# VITE_SITE_URL=https://www.example.com
